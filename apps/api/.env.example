DASHFORGE_ENV=local
DASHFORGE_DATABASE_URL=sqlite:///./storage/dashforge.db
DASHFORGE_STORAGE_DIR=./storage
DASHFORGE_ALLOWED_ORIGINS=http://localhost:3000
DASHFORGE_LLM_PROVIDER=none
DASHFORGE_LLM_BASE_URL=https://api.openai.com/v1
DASHFORGE_LLM_API_KEY=
DASHFORGE_LLM_MODEL=gpt-4.1-mini
DASHFORGE_ROUTER_BASE_URL=https://openrouter.ai/api/v1
DASHFORGE_ROUTER_API_KEY=
DASHFORGE_ROUTER_MODEL=openai/gpt-4.1-mini

