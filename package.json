{
  "name": "dashforge-core",
  "private": true,
  "version": "0.1.0",
  "description": "Expert-in-the-loop data-to-dashboard accelerator monorepo.",
  "scripts": {
    "dev:web": "pnpm --filter @dashforge/web dev",
    "build:web": "pnpm --filter @dashforge/web build",
    "lint:web": "pnpm --filter @dashforge/web lint",
    "test:api": "cd apps/api && pytest",
    "dev:api": "cd apps/api && uvicorn app.main:app --reload --port 8000"
  },
  "workspaces": [
    "apps/web"
  ],
  "packageManager": "pnpm@9.12.0"
}

